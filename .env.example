# KRAVIA Company OS foundation environment example
# Copy values into your local shell, .env loader, or deployment secret manager.

PORT=8080
DATABASE_URL=jdbc:postgresql://localhost:5432/kravia_companyos
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres
KRAVIA_JWT_SECRET=replace-with-a-long-random-secret-of-at-least-32-characters
KRAVIA_ALLOWED_ORIGINS=http://localhost:4200
KRAVIA_JWT_EXPIRATION_MINUTES=480

# Secure local document storage for development. Do not commit files from this path.
KRAVIA_DOCUMENT_STORAGE_ROOT=./storage/private-documents
KRAVIA_DOCUMENT_MAX_FILE_SIZE_BYTES=26214400
KRAVIA_DOCUMENT_MULTIPART_MAX_SIZE=25MB
KRAVIA_DOCUMENT_MULTIPART_MAX_REQUEST_SIZE=30MB
KRAVIA_DOCUMENT_ALLOWED_CONTENT_TYPES=application/pdf,image/png,image/jpeg,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/vnd.ms-excel,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,text/plain

# Optional first-run founder bootstrap. Remove after the account exists.
KRAVIA_BOOTSTRAP_FOUNDER_EMAIL=founder@kravia.local
KRAVIA_BOOTSTRAP_FOUNDER_PASSWORD=replace-with-a-strong-temporary-password
KRAVIA_BOOTSTRAP_FOUNDER_NAME=Founder
